# Advanced Java Calculator - .gitignore
# ============================================

# Compiled Java class files
*.class

# Build output directories
bin/
build/
out/
target/

# Packaged Java files
*.jar
*.war
*.ear

# Log files
*.log

# JVM crash logs
hs_err_pid*
replay_pid*

# VS Code
.vscode/

# IntelliJ IDEA
.idea/
*.iml

# Eclipse
.project
.classpath
.settings/

# NetBeans
nbproject/private/

# Operating System files
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
